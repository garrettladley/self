{
  "name": "garrettladley-com",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "typecheck": "astro check",
    "lint": "eslint . --cache",
    "lint:fix": "eslint . --fix --cache",
    "a11y": "axe http://localhost:4321 http://localhost:4321/projects http://localhost:4321/library http://localhost:4321/404 --exit",
    "format": "oxfmt --write . && prettier --write \"src/**/*.astro\"",
    "format:check": "oxfmt --check . && prettier --check \"src/**/*.astro\"",
    "vercel:bootstrap": "bash ./scripts/vercel-bootstrap.sh",
    "preview": "astro preview",
    "astro": "astro"
  },
  "dependencies": {
    "@astrojs/vercel": "^9.0.4",
    "@tailwindcss/vite": "^4.2.0",
    "@vercel/analytics": "^1.6.1",
    "@vercel/speed-insights": "^1.3.1",
    "astro": "^5.17.1",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.2.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.6",
    "@axe-core/cli": "^4.11.1",
    "@eslint/css": "^0.14.1",
    "@eslint/js": "^9.39.3",
    "@poupe/eslint-plugin-tailwindcss": "^0.2.4",
    "@types/node": "^25.3.0",
    "browser-driver-manager": "^2.0.1",
    "eslint": "^9.39.3",
    "eslint-plugin-astro": "^1.6.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "globals": "^17.3.0",
    "oxfmt": "^0.34.0",
    "prettier": "^3.8.1",
    "prettier-plugin-astro": "^0.14.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "packageManager": "pnpm@10.30.1",
  "pnpm": {
    "overrides": {
      "lodash": ">=4.17.23"
    },
    "onlyBuiltDependencies": [
      "@poupe/eslint-plugin-tailwindcss",
      "chromedriver"
    ]
  }
}
