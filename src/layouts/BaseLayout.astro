---
import "../styles/global.css";
import { ClientRouter } from "astro:transitions";
import SpeedInsights from "@vercel/speed-insights/astro";
import Analytics from "@vercel/analytics/astro";
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";
import CommandPalette from "../components/CommandPalette.astro";

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  noIndex?: boolean;
}

const SITE = "https://garrettladley.com";

const {
  title = "Garrett Ladley",
  description = "Garrett Ladley, Member of Technical Staff at Agency AI.",
  ogImage = "/og.png",
  noIndex = false,
} = Astro.props;

const canonical = new URL(Astro.url.pathname, SITE);
const ogImageUrl = new URL(ogImage, SITE).href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="author" content="Garrett Ladley" />
    <meta name="generator" content={Astro.generator} />

    {/* Open Graph */}
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Garrett Ladley" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical.href} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={title} />

    {/* Twitter / X */}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@GarrettLadley" />
    <meta name="twitter:creator" content="@GarrettLadley" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <link rel="canonical" href={canonical.href} />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon.png" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link
      rel="preload"
      href="/fonts/lilex-latin-400-normal.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <meta name="theme-color" content="#2a334f" />
    {noIndex && <meta name="robots" content="noindex" />}
    <title>{title}</title>
    <ClientRouter fallback="swap" />

    {/* JSON-LD Structured Data */}
    <script
      type="application/ld+json"
      set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "ProfilePage",
        mainEntity: {
          "@type": "Person",
          name: "Garrett Ladley",
          url: SITE,
          description:
            "Software engineer specializing in Go and Rust, passionate about building products, backend development, and distributed systems. Member of Technical Staff at Agency AI in New York City.",
          jobTitle: "Member of Technical Staff",
          worksFor: { "@type": "Organization", name: "Agency AI" },
          knowsAbout: [
            "Go",
            "Rust",
            "Backend Development",
            "Distributed Systems",
            "AI Agents",
            "Infrastructure",
          ],
          alumniOf: [
            {
              "@type": "CollegeOrUniversity",
              name: "Northeastern University",
            },
            {
              "@type": "HighSchool",
              name: "New Canaan High School",
            },
            {
              "@type": "MiddleSchool",
              name: "Hong Kong International School",
            },
          ],
          sameAs: [
            "https://github.com/garrettladley",
            "https://x.com/GarrettLadley",
            "https://linkedin.com/in/garrett-ladley",
          ],
        },
      })}
    />
  </head>
  <body class="min-h-dvh bg-background text-foreground font-mono antialiased">
    <div class="min-h-dvh flex flex-col">
      <SiteHeader currentPath={Astro.url.pathname} />
      <slot />
      <SiteFooter />
    </div>
    <CommandPalette />
    <SpeedInsights />
    <Analytics />
  </body>
</html>
