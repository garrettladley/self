---
const now = new Date();
const dd = String(now.getDate()).padStart(2, "0");
const mm = String(now.getMonth() + 1).padStart(2, "0");
const yyyy = now.getFullYear();
const dmy = `${dd}/${mm}/${yyyy}`;
const mdy = `${mm}/${dd}/${yyyy}`;
---

<footer
  class="fixed bottom-0 left-0 right-0 z-20 flex flex-wrap items-center justify-between gap-x-6 gap-y-1 border-t border-border bg-background px-page-x py-3 font-mono text-[10px] uppercase tracking-[0.15em] text-foreground-muted shrink-0"
  transition:persist
  transition:animate="none"
>
  <nav aria-label="Social links" class="flex items-center gap-x-3">
    <a
      href="https://github.com/garrettladley"
      target="_blank"
      rel="noreferrer"
      aria-label="GitHub (github.com/garrettladley)"
      class="no-underline transition-colors duration-150 hover:text-accent"
    >
      GitHub
    </a>
    <span role="separator">|</span>
    <a
      href="https://x.com/GarrettLadley"
      target="_blank"
      rel="noreferrer"
      aria-label="X (x.com/GarrettLadley)"
      class="no-underline transition-colors duration-150 hover:text-accent"
    >
      X
    </a>
    <span role="separator">|</span>
    <a
      href="https://linkedin.com/in/garrett-ladley/"
      target="_blank"
      rel="noreferrer"
      aria-label="LinkedIn (linkedin.com/in/garrett-ladley)"
      class="no-underline transition-colors duration-150 hover:text-accent"
    >
      LinkedIn
    </a>
  </nav>
  <span
    >LAST BUILD: <span
      id="last-build"
      class="cursor-pointer select-none transition-colors duration-150 hover:text-accent"
      title="Click to toggle format"
      data-dmy={dmy}
      data-mdy={mdy}>{dmy}</span
    ></span
  >
</footer>

<script is:inline data-astro-rerun>
  (function () {
    const el = document.getElementById("last-build");
    if (!el || el.__buildEvents) return;
    el.__buildEvents = true;

    if (window.__buildUseMDY === undefined) window.__buildUseMDY = false;

    function current() {
      return window.__buildUseMDY ? el.dataset.mdy : el.dataset.dmy;
    }
    function alt() {
      return window.__buildUseMDY ? el.dataset.dmy : el.dataset.mdy;
    }
    function render() {
      el.textContent = current();
    }

    render();

    el.addEventListener("mouseenter", function () {
      el.textContent = alt();
    });
    el.addEventListener("mouseleave", function () {
      render();
    });
    el.addEventListener("click", function () {
      window.__buildUseMDY = !window.__buildUseMDY;
      render();
    });
  })();
</script>
