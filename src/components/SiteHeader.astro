---
interface Props {
  currentPath?: string;
}

const { currentPath = "" } = Astro.props;

const navLinks = [
  { href: "/projects", label: "Projects" },
  { href: "/library", label: "Library" },
];
---

<header
  class="fixed top-0 left-0 right-0 z-20 flex h-15 items-center justify-between border-b border-border bg-background px-page-x font-mono text-[10px] uppercase tracking-[0.2em]"
  transition:name="site-header"
  transition:persist
  transition:animate="none"
>
  <div class="flex items-center gap-x-4">
    <a
      href="/"
      data-nav-home
      class:list={[
        "whitespace-nowrap transition-colors duration-150 no-underline",
        currentPath === "/"
          ? "text-accent cursor-default"
          : "text-foreground-muted hover:text-accent",
      ]}
    >
      Garrett Ladley
    </a>
    <span class="hidden sm:inline text-border" role="separator">/</span>
    <nav
      aria-label="Site navigation"
      class="hidden sm:flex items-center gap-x-3"
    >
      {
        navLinks.map((link, i) => (
          <>
            {i > 0 && (
              <span class="text-border" role="separator">
                ·
              </span>
            )}
            <a
              href={link.href}
              data-nav-link
              class:list={[
                "transition-colors duration-150 no-underline",
                currentPath.startsWith(link.href)
                  ? "text-accent hover:text-accent cursor-default"
                  : "text-foreground-muted hover:text-accent",
              ]}
            >
              {link.label}
            </a>
          </>
        ))
      }
    </nav>
  </div>
  <div class="flex items-center gap-x-4">
    <div
      class="hidden sm:block text-foreground-muted cursor-pointer select-none"
      id="clock"
      title="Click to toggle format"
    >
      00:00:00
    </div>
    <button
      id="menu-toggle"
      class="sm:hidden text-foreground-muted hover:text-accent transition-colors duration-150 p-1"
      aria-label="Toggle menu"
      aria-expanded="false"
    >
      <svg
        width="18"
        height="18"
        viewBox="0 0 18 18"
        fill="none"
        stroke="currentColor"
        stroke-width="1.5"
        stroke-linecap="round"
      >
        <line x1="2" y1="4.5" x2="16" y2="4.5" class="menu-top"></line>
        <line x1="2" y1="9" x2="16" y2="9" class="menu-mid"></line>
        <line x1="2" y1="13.5" x2="16" y2="13.5" class="menu-bot"></line>
      </svg>
    </button>
  </div>
</header>

<!-- Mobile menu overlay -->
<div
  id="mobile-menu"
  class="fixed inset-0 z-10 hidden sm:hidden!"
  transition:persist
>
  <div class="absolute inset-0 bg-background/95 backdrop-blur-sm"></div>
  <nav
    class="relative flex flex-col items-start gap-y-6 px-page-x pt-20 font-mono text-[10px] uppercase tracking-[0.2em]"
    aria-label="Mobile navigation"
  >
    {
      navLinks.map((link) => (
        <a
          href={link.href}
          data-nav-link
          data-mobile-link
          class:list={[
            "transition-colors duration-150 no-underline",
            currentPath.startsWith(link.href)
              ? "text-accent hover:text-accent cursor-default"
              : "text-foreground-muted hover:text-accent",
          ]}
        >
          {link.label}
        </a>
      ))
    }
  </nav>
</div>

<script is:inline data-astro-rerun>
  (function () {
    const header = document.querySelector("[data-nav-home]");
    if (!header) return;

    // Guard against duplicate clock intervals from persist + rerun
    if (!window.__clockInterval) {
      // Default to 12h; persisted across navigations via window
      if (window.__clockUse24h === undefined) window.__clockUse24h = false;

      function formatTime(now, use24h) {
        let h = now.getHours();
        const m = String(now.getMinutes()).padStart(2, "0");
        const s = String(now.getSeconds()).padStart(2, "0");
        if (use24h) return String(h).padStart(2, "0") + ":" + m + ":" + s;
        h = h % 12 || 12;
        return String(h).padStart(2, "0") + ":" + m + ":" + s;
      }

      function updateClock() {
        const now = new Date();
        const el = document.getElementById("clock");
        if (!el) return;
        el.textContent = formatTime(now, window.__clockUse24h);
        el.dataset.alt = formatTime(now, !window.__clockUse24h);
      }

      window.__clockInterval = setInterval(updateClock, 1000);
      updateClock();

      // Hover: show the alternate format; unhover: restore
      const clockEl = document.getElementById("clock");
      if (clockEl && !clockEl.__clockEvents) {
        clockEl.__clockEvents = true;
        clockEl.addEventListener("mouseenter", function () {
          clockEl.textContent = clockEl.dataset.alt || clockEl.textContent;
        });
        clockEl.addEventListener("mouseleave", function () {
          updateClock();
        });
        clockEl.addEventListener("click", function () {
          window.__clockUse24h = !window.__clockUse24h;
          updateClock();
        });
      }
    }

    const path = window.location.pathname;
    const activeClass =
      "transition-colors duration-150 no-underline text-accent hover:text-accent cursor-default";
    const inactiveClass =
      "transition-colors duration-150 no-underline text-foreground-muted hover:text-accent";
    const homeActiveClass = "whitespace-nowrap " + activeClass;
    const homeInactiveClass = "whitespace-nowrap " + inactiveClass;
    const mobileActiveClass = activeClass;
    const mobileInactiveClass = inactiveClass;

    const home = document.querySelector("[data-nav-home]");
    if (home) {
      home.className = path === "/" ? homeActiveClass : homeInactiveClass;
    }
    document.querySelectorAll("[data-nav-link]").forEach(function (el) {
      const isMobile = el.hasAttribute("data-mobile-link");
      const active = path.startsWith(el.getAttribute("href"));
      if (isMobile) {
        el.className = active ? mobileActiveClass : mobileInactiveClass;
      } else {
        el.className = active ? activeClass : inactiveClass;
      }
    });

    // Mobile menu toggle
    const menuToggle = document.getElementById("menu-toggle");
    const mobileMenu = document.getElementById("mobile-menu");
    if (menuToggle && mobileMenu && !menuToggle.__menuBound) {
      menuToggle.__menuBound = true;
      menuToggle.addEventListener("click", function () {
        const isOpen = !mobileMenu.classList.contains("hidden");
        mobileMenu.classList.toggle("hidden", isOpen);
        menuToggle.setAttribute("aria-expanded", String(!isOpen));
      });
      // Close menu when a mobile link is clicked
      mobileMenu.addEventListener("click", function (e) {
        if (e.target.closest("[data-mobile-link]")) {
          mobileMenu.classList.add("hidden");
          menuToggle.setAttribute("aria-expanded", "false");
        }
      });
    }
    // Ensure mobile menu is closed on navigation
    if (mobileMenu) {
      mobileMenu.classList.add("hidden");
      if (menuToggle) menuToggle.setAttribute("aria-expanded", "false");
    }

    // Single delegated listener on the header to block clicks on active links
    const headerEl = document.querySelector("header");
    if (headerEl && !headerEl.__navGuard) {
      headerEl.__navGuard = true;
      headerEl.addEventListener("click", function (e) {
        const link = e.target.closest("[data-nav-home], [data-nav-link]");
        if (!link) return;
        const cur = window.location.pathname;
        const href = link.getAttribute("href");
        if (href === "/" ? cur === "/" : cur.startsWith(href)) {
          e.preventDefault();
        }
      });
    }
  })();
</script>
