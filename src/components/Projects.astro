---
type Project = {
  name: string;
  description: string;
  href?: string;
  private?: boolean;
  tools: string[];
};

const projects: Project[] = [
  {
    name: "intern",
    private: true,
    description: "Sandboxed background agents running your infrastructure",
    tools: ["Go"],
  },
  {
    name: "thoop",
    href: "https://github.com/garrettladley/thoop",
    description: "TUI for your WHOOP",
    tools: ["Go"],
  },
  {
    name: "peli",
    href: "https://github.com/garrettladley/peli",
    description: "Beli-style restaurant ranking TUI",
    tools: ["Go"],
  },
  {
    name: "smerkle",
    href: "https://github.com/garrettladley/smerkle",
    description: "Exploring merkle trees",
    tools: ["Go"],
  },
  {
    name: "strumbra",
    href: "https://github.com/garrettladley/strumbra",
    description: "Umbra strings",
    tools: ["Go"],
  },
  {
    name: "repo_reaper",
    href: "https://github.com/garrettladley/repo_reaper",
    description: "Information retrieval CLI for code search",
    tools: ["Rust"],
  },
];
---

<section class="px-page-x py-8">
  <div
    class="text-center font-mono text-[11px] uppercase tracking-[0.1em] text-foreground-muted mb-6"
  >
    ACTIVE PROJECTS
  </div>

  <div
    class="flex flex-col w-full font-mono text-[11px] tracking-[0.05em] uppercase"
  >
    {
      projects.map((project) => (
        <div class="grid grid-cols-[clamp(120px,20vw,200px)_1fr] gap-2 border-t border-border py-2 transition-all duration-200 hover:text-accent hover:pl-2">
          <div class="flex justify-between pr-4 text-foreground-muted">
            <span>
              {project.name}
              {project.private && " (pvt)"}
            </span>
            <span>&gt;</span>
          </div>
          <div class="overflow-hidden text-ellipsis whitespace-nowrap">
            {project.href ? (
              <a
                href={project.href}
                target="_blank"
                rel="noreferrer"
                class="no-underline"
                title={project.href}
              >
                {project.description}
              </a>
            ) : (
              project.description
            )}
            {project.tools.length > 0 && (
              <span class="opacity-60"> · {project.tools.join(" · ")}</span>
            )}
          </div>
        </div>
      ))
    }
    <div class="border-t border-border"></div>
  </div>
</section>
