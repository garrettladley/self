---

---

<section
  class="grid grid-cols-1 border-t border-border md:grid-cols-[1.5fr_1fr] shrink-0"
>
  <!-- Panel 1: Name -->
  <div
    class="flex flex-col justify-center border-b border-border p-page-x py-6 md:border-b-0"
  >
    <h1
      class="text-[clamp(2.5rem,5vw,5rem)] leading-[0.85] font-light tracking-[-0.04em] uppercase"
    >
      Garrett<br />Ladley<span
        class="inline-block align-baseline [animation:cursor_1s_steps(1,end)_infinite]"
        >█</span
      >
    </h1>
  </div>

  <!-- Panel 2: Data readout -->
  <div class="flex flex-col justify-center p-page-x py-6">
    <div
      class="flex flex-col w-full font-mono text-[10px] tracking-[0.1em] uppercase"
    >
      <div
        class="grid grid-cols-2 gap-2 border-t border-border py-2.5 transition-all duration-200 hover:pl-2 hover:bg-white/[0.02]"
      >
        <div class="text-foreground-muted">ROLE</div>
        <div class="text-right text-foreground whitespace-nowrap">
          MTS AT AGENCY AI
        </div>
      </div>
      <div
        class="grid grid-cols-2 gap-2 border-t border-border py-2.5 transition-all duration-200 hover:pl-2 hover:bg-white/[0.02]"
      >
        <div class="text-foreground-muted">LOCATION</div>
        <div class="text-right text-foreground">NEW YORK CITY</div>
      </div>
      <div
        class="grid grid-cols-2 gap-2 border-t border-border py-2.5 transition-all duration-200 hover:pl-2 hover:bg-white/[0.02]"
      >
        <div class="text-foreground-muted">FOCUS</div>
        <div class="text-right text-foreground">GO · RUST</div>
      </div>
      <div
        class="grid grid-cols-2 gap-2 border-y border-border py-2.5 transition-all duration-200 hover:pl-2 hover:bg-white/[0.02]"
      >
        <div class="text-foreground-muted">FRAME RATE</div>
        <div class="text-right text-accent" id="fps-readout">-- FPS</div>
      </div>
    </div>
  </div>
</section>
