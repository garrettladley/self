---

<header
  class="fixed top-0 left-0 right-0 z-20 flex h-[60px] items-center justify-between border-b border-border bg-background px-page-x font-mono text-[10px] uppercase tracking-[0.2em]"
>
  <div class="text-foreground-muted">Garrett Ladley</div>
  <div class="text-foreground-muted" id="clock">00:00:00</div>
</header>

<script is:inline>
  (function () {
    function updateClock() {
      var now = new Date();
      var h = String(now.getHours()).padStart(2, "0");
      var m = String(now.getMinutes()).padStart(2, "0");
      var s = String(now.getSeconds()).padStart(2, "0");
      var el = document.getElementById("clock");
      if (el) el.textContent = h + ":" + m + ":" + s;
    }
    setInterval(updateClock, 1000);
    updateClock();
  })();
</script>
