---
import BaseLayout from "../layouts/BaseLayout.astro";
import { projects } from "../data/projects";
---

<BaseLayout
  title="Projects — Garrett Ladley"
  description="Active projects by Garrett Ladley."
>
  <main
    class="mx-auto w-full max-w-page px-page-x pt-[calc(60px+var(--page-padding-block))] pb-[calc(60px+var(--page-padding-block))] flex-1 flex flex-col justify-center"
  >
    <h1 class="sr-only">Projects</h1>
    <div
      class="flex flex-col w-full font-mono text-[15px] tracking-[0.04em] uppercase gap-1"
    >
      {
        projects.map((project) => (
          <div class="grid grid-cols-[clamp(160px,24vw,280px)_1fr] gap-8 py-5 border-b border-white/[0.04] last:border-b-0">
            <div class="flex justify-between pr-4 text-foreground-muted">
              <span>
                {project.href ? (
                  <a
                    href={project.href}
                    target="_blank"
                    rel="noreferrer"
                    class="transition-colors duration-200 hover:text-accent"
                  >
                    {project.name}
                  </a>
                ) : (
                  project.name
                )}
                {project.private && (
                  <span class="text-foreground-dim text-[13px]">
                    {" "}
                    (private)
                  </span>
                )}
              </span>
              <span class="text-foreground-dim">&gt;</span>
            </div>
            <div class="overflow-hidden text-ellipsis whitespace-nowrap">
              {project.description}
              {project.tools.length > 0 && (
                <span class="text-foreground-dim text-[13px]">
                  {" "}
                  · {project.tools.join(" · ")}
                </span>
              )}
            </div>
          </div>
        ))
      }
    </div>
  </main>
</BaseLayout>
